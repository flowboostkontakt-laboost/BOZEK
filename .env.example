# ─── Baza danych (PostgreSQL + pgvector) ─────────────────────────────
DATABASE_URL="postgresql://sep:sep@localhost:5432/sep?schema=public"

# ─── Autoryzacja (JWT) ───────────────────────────────────────────────
JWT_ACCESS_SECRET="zmien_mnie_na_dlugi_losowy_ciag"
JWT_REFRESH_SECRET="zmien_mnie_na_inny_dlugi_losowy_ciag"
JWT_ACCESS_TTL="30m"
JWT_REFRESH_TTL="7d"

# Twarde wylogowanie pracownic o tej godzinie (wymaganie spec 2.1)
AUTO_LOGOUT_HOUR="18"
TZ="Europe/Warsaw"

# ─── Integracja PrestaShop (Webservice API) ──────────────────────────
PRESTASHOP_API_URL="https://twojsklep.pl/api"
PRESTASHOP_API_KEY="zmien_mnie"
# Godzina dobowej synchronizacji (cron), format HH:MM
SYNC_CRON_TIME="03:00"

# ─── Moduł AI rozpoznawania ze zdjęcia (Wariant A) ───────────────────
# local = embeddingi CLIP liczone na serwerze (transformers.js)
# api   = zewnętrzny dostawca vision (klucz poniżej)
AI_PROVIDER="local"
AI_API_KEY=""
# Próg pewności dopasowania (0-1). Poniżej → pozycja trafia do kolejki "Do sprawdzenia".
AI_MATCH_THRESHOLD="0.78"

# ─── Serwer / API ────────────────────────────────────────────────────
PORT="3000"
WEB_ORIGIN="http://localhost:5173"
